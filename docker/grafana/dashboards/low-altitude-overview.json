{
  "uid": "low-altitude-overview",
  "title": "Low Altitude Platform Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "HTTP Requests by Service",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum by (application, uri) (rate(http_server_requests_seconds_count[1m]))", "legendFormat": "{{application}} {{uri}}"}
      ]
    },
    {
      "id": 2,
      "title": "HTTP 95th Percentile Latency",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, application) (rate(http_server_requests_seconds_bucket[1m])))", "legendFormat": "{{application}} p95"}
      ]
    },
    {
      "id": 3,
      "title": "Outbox Pending / Failed",
      "type": "stat",
      "gridPos": {"x": 0, "y": 8, "w": 8, "h": 6},
      "targets": [
        {"expr": "low_altitude_outbox_pending", "legendFormat": "pending"},
        {"expr": "low_altitude_outbox_failed", "legendFormat": "failed"}
      ]
    },
    {
      "id": 4,
      "title": "Occupied Resource Slices",
      "type": "stat",
      "gridPos": {"x": 8, "y": 8, "w": 8, "h": 6},
      "targets": [
        {"expr": "low_altitude_resource_occupancy_occupied", "legendFormat": "occupied"}
      ]
    },
    {
      "id": 5,
      "title": "Notification / Idempotency Counters",
      "type": "stat",
      "gridPos": {"x": 16, "y": 8, "w": 8, "h": 6},
      "targets": [
        {"expr": "low_altitude_notify_sent", "legendFormat": "notify sent"},
        {"expr": "low_altitude_idempotent_processed", "legendFormat": "idempotent processed"},
        {"expr": "low_altitude_audit_total", "legendFormat": "audit total"}
      ]
    },
    {
      "id": 6,
      "title": "Resilience4j Governance Demo Metrics",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 14, "w": 24, "h": 8},
      "targets": [
        {"expr": "increase(low_altitude_governance_rate_limited_total[5m])", "legendFormat": "rate limited"},
        {"expr": "increase(low_altitude_governance_circuit_fallback_total[5m])", "legendFormat": "circuit fallback"},
        {"expr": "increase(low_altitude_governance_retry_success_total[5m])", "legendFormat": "retry success"}
      ]
    }
  ]
}
